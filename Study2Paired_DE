# -------------------------
# Function to create and save heatmaps
# -------------------------
create_heatmaps <- function(sig_mirnas, category, meta_filtered, counts_filtered) {
  
  # Subset to category only
  meta_sub <- meta_filtered[meta_filtered$Category == category, ]
  counts_sub <- counts_filtered[, meta_sub$Sample_ID]
  
  # Build DGE and logCPM
  dge_sub <- DGEList(counts = counts_sub)
  dge_sub <- calcNormFactors(dge_sub, method = "TMM")
  logCPM_sub <- cpm(dge_sub, log = TRUE, prior.count = 1)
  
  genes <- intersect(sig_mirnas, rownames(logCPM_sub))
  message(paste(category, "- miRNAs found in logCPM:", length(genes)))
  
  # Order by Timepoint
  ord <- order(meta_sub$Timepoint)
  logCPM_ord <- logCPM_sub[genes, ord, drop = FALSE]
  meta_ord <- meta_sub[ord, ]
  
  # Row z-score
  mat_z <- t(scale(t(logCPM_ord)))
  
  # Annotation
  ann_col <- data.frame(Timepoint = meta_ord$Timepoint)
  rownames(ann_col) <- meta_ord$Sample_ID
  
  # ---- Heatmap 1: Per-sample ----
  png(paste0("/Users/viraa/TestingCode/Testing_Monkey/Study2/Heatmap_", category, "_PerSample.png"),
      width = 5, height = 1.5, units = "in", res = 300)
  pheatmap(mat_z,
           annotation_col = ann_col,
           show_colnames = FALSE,
           cluster_cols = FALSE,
           fontsize_row = 8,
           main = paste0(" ", category, " (Post vs Baseline)"))
  dev.off()
  
  message(paste("Saved heatmaps for", category))
}

