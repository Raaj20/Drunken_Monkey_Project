setwd("/Users/viraa/TestingCode/Testing_Monkey/Study2")
dge_filtered <- read.csv("filtered_miRNA_counts.csv", row.names = 1, check.names = FALSE)

# Original counts column names
colnames(dge_filtered)

# Clean them to match metadata:
# Example: 10360_B_S33 -> 10360B
colnames(dge_filtered) <- gsub("_B_.*", "B", colnames(dge_filtered))
colnames(dge_filtered) <- gsub("_P_.*", "P", colnames(dge_filtered))

# Check
colnames(dge_filtered)

# -------------------------
# 2️⃣ Load and clean metadata
# -------------------------
meta <- read.csv("sample_metadata.csv", stringsAsFactors = FALSE)


# Trim whitespace and set factor levels
meta$Sample_ID <- trimws(meta$Sample_ID)
meta$Timepoint <- factor(trimws(meta$Timepoint), levels = c("baseline", "post"))
meta$Sex <- factor(trimws(meta$Sex), levels = c("F", "M"))
meta$Category <- factor(trimws(meta$Category), levels = c("LD", "BD", "HD"))
common_samples <- intersect(colnames(dge_filtered), meta$Sample_ID)

counts_filtered <- dge_filtered[, colnames(dge_filtered) %in% meta$Sample_ID]
meta_filtered <- meta[meta$Sample_ID %in% common_samples, ]

# Reorder metadata to match counts
meta_filtered <- meta_filtered[match(colnames(counts_filtered), meta_filtered$Sample_ID), ]

# Check that all sample IDs match
if(!all(colnames(counts_filtered) == meta_filtered$Sample_ID)) {
  stop("Sample IDs in counts and metadata do not match!")
}

# -------------------------
# Split into baseline and post AFTER normalization
# -------------------------
baseline_samples <- meta_filtered$Sample_ID[meta_filtered$Timepoint == "baseline"]
post_samples     <- meta_filtered$Sample_ID[meta_filtered$Timepoint == "post"]

logCPM_baseline <- logCPM_all[, baseline_samples]
logCPM_post     <- logCPM_all[, post_samples]

write.csv(logCPM_baseline, "Normalized_logCPM_baseline.csv")
write.csv(logCPM_post,     "Normalized_logCPM_post.csv")



# -------------------------
# Paired Post vs Baseline DE analysis
# -------------------------
# Extract subject ID from sample names (e.g. "10360B" -> "10360")
meta_filtered$Subject <- gsub("[BP]$", "", meta_filtered$Sample_ID)
meta_filtered$Subject <- as.factor(meta_filtered$Subject)
meta_filtered <- meta_filtered[order(meta_filtered$Subject, meta_filtered$Timepoint), ]
counts_filtered <- counts_filtered[, meta_filtered$Sample_ID]

categories <- unique(meta_filtered$Category)

for (cat in categories) {
  meta_sub <- meta_filtered[meta_filtered$Category == cat, ]
  meta_sub <- droplevels(meta_sub)
  
  n_subjects <- length(unique(meta_sub$Subject))
  if (n_subjects < 2) {
    message("Skipping ", cat, " — only ", n_subjects, " subject(s)")
    next
  }
  
  counts_sub <- counts_filtered[, meta_sub$Sample_ID]
  design_sub <- model.matrix(~ Subject + Timepoint, data = meta_sub)
  
  dge_sub <- DGEList(counts = counts_sub)
  dge_sub <- calcNormFactors(dge_sub, method = "TMM")
  dge_sub <- estimateDisp(dge_sub, design_sub)
  fit_sub <- glmQLFit(dge_sub, design_sub)
  qlf_sub <- glmQLFTest(fit_sub, coef = "Timepointpost")
  
  res <- topTags(qlf_sub, n = Inf)
  write.csv(res$table, paste0("/Users/viraa/TestingCode/Testing_Monkey/Study2", cat, ".csv"))
  message("Done: ", cat)
}


