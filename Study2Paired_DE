read_panther <- function(filepath, group_label) {
  all_lines <- read_lines(filepath)
  start_line <- which(str_detect(all_lines, "^PANTHER GO-Slim Biological Process")) + 1
  
  read_tsv(filepath, skip = start_line, show_col_types = FALSE) %>%
    setNames(c(
      "Pathway", "Ref_count", "Hit_count", "Expected",
      "OverUnder", "FoldEnrichment", "RawPvalue", "FDR"
    )) %>%
    mutate(
      Pathway = str_remove(Pathway, " \\([^)]+\\)$"),
      RawPvalue = as.numeric(str_replace(RawPvalue, "< 1e-5", "0.009")),
      FoldEnrichment = as.numeric(FoldEnrichment),
      FDR = as.numeric(FDR),
      logFDR = -log10(FDR),
      Comparison = group_label
    )
}

# --- Filter function: adjust thresholds here ---
prep_plot_data <- function(data, min_hits = 10, min_fold = 1.2, top_n = 15) {
  data %>%
    filter(FDR < 0.05) %>%
    filter(Hit_count > min_hits) %>%        # <-- gene count filter
    filter(FoldEnrichment > min_fold) %>%   # <-- fold change filter
    arrange(desc(FoldEnrichment)) %>%       # sort highest to lowest
    slice_head(n = top_n)                   # take top N after sorting
}

# --- Load both groups ---
pathway_BDSlim <- read_panther("BDanalysis.txt", "BD")
pathway_LDSlim <- read_panther("LDanalysis.txt", "LD")

# --- Combine and reorder Y-axis by max FoldEnrichment across groups ---
plot_data <- bind_rows(
  prep_plot_data(pathway_BDSlim),
  prep_plot_data(pathway_LDSlim)
) %>%
  mutate(Pathway = str_trunc(Pathway, 60),
         Pathway = fct_reorder(Pathway, FoldEnrichment, .fun = max))

# --- Plot ---
